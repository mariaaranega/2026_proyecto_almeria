@article{boggs_forecasting_2014,
	address = {Hoboken},
	title = {Forecasting {Natural} {Aquifer} {Discharge} {Using} a {Numerical} {Model} and {Convolution}},
	volume = {52},
	issn = {0017-467X, 1745-6584},
	doi = {10.1111/gwat.12096},
	abstract = {If the nature of groundwater sources and sinks can be determined or predicted, the data can be used to forecast natural aquifer discharge. We present a procedure to forecast the relative contribution of individual aquifer sources and sinks to natural aquifer discharge. Using these individual aquifer recharge components, along with observed aquifer heads for each January, we generate a 1-year, monthly spring discharge forecast for the upcoming year with an existing numerical model and convolution. The results indicate that a forecast of natural aquifer discharge can be developed using only the dominant aquifer recharge sources combined with the effects of aquifer heads (initial conditions) at the time the forecast is generated. We also estimate how our forecast will perform in the future using a jackknife procedure, which indicates that the future performance of the forecast is good (Nash-Sutcliffe efficiency of 0.81). We develop a forecast and demonstrate important features of the procedure by presenting an application to the Eastern Snake Plain Aquifer in southern Idaho.},
	language = {English},
	number = {4},
	journal = {Groundwater},
	publisher = {Wiley},
	author = {Boggs, Kevin G. and Johnson, Gary S. and Van Kirk, Rob and Fairley, Jerry P.},
	month = aug,
	year = {2014},
	note = {Num Pages: 11
Web of Science ID: WOS:000347979400006},
	keywords = {GROUNDWATER DISCHARGE, STREAM},
	pages = {503--513},
}

