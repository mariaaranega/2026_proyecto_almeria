@article{manteca_hydric_2012,
	title = {Hydric {Restoration} of the {Agua} {Amarga} {Salt} {Marsh} ({SE} {Spain}) {Affected} by {Abstraction} from the {Underlying} {Coastal} {Aquifer}},
